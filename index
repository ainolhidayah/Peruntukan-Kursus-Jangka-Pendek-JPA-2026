        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        /* Menyembunyikan butang spin lalai pada input nombor */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type=number] {
            -moz-appearance: textfield;
        }

        /* */
        @media print {
            /* Tetapan Saiz Kertas & Orientasi */
            @page {
                size: landscape;
                margin: 10mm 8mm 10mm 8mm;
            }

            /* Sembunyikan elemen interaktif yang tidak diperlukan pada cetakan */
            .no-print, 
            button, 
            #search-input, 
            .col-actions, 
            #course-modal, 
            #delete-modal, 
            #notification-toast,
            .print-hint {
                display: none !important;
            }

            /* Struktur Halaman untuk Cetakan */
            body {
                background-color: #ffffff !important;
                color: #000000 !important;
                font-size: 10pt !important;
                padding: 0 !important;
                margin: 0 !important;
            }

            main {
                max-width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
            }

            /* Batalkan Scrollbar untuk mendedahkan semua data */
            .overflow-x-auto {
                overflow: visible !important;
                overflow-x: visible !important;
                max-width: 100% !important;
            }

            /* Struktur Jadual Cetakan */
            table {
                width: 100% !important;
                table-layout: auto !important;
                border-collapse: collapse !important;
                font-size: 8.5pt !important; /* Saiz fon kecil sedikit supaya muat semua lajur */
            }

            th, td {
                border: 1px solid #cbd5e1 !important; /* Border kelabu yang jelas pada kertas */
                padding: 6px 8px !important;
                color: #000000 !important;
            }

            th {
                background-color: #f1f5f9 !important;
                font-weight: bold !important;
            }

            /* Halang baris jadual terputus antara muka surat */
            tr {
                page-break-inside: avoid !important;
            }

            /* Tukarkan Input kepada teks biasa pada cetakan */
            input[type="number"] {
                border: none !important;
                background: transparent !important;
                text-align: right !important;
                width: auto !important;
                padding: 0 !important;
                box-shadow: none !important;
            }

            select {
                appearance: none !important;
                -webkit-appearance: none !important;
                border: none !important;
                background: transparent !important;
                padding: 0 !important;
                font-weight: bold !important;
            }

            /* Pembahagian Grid Tandatangan Kekal 2 Lajur */
            .print-grid-signatures {
                display: grid !important;
                grid-template-columns: 1fr 1fr !important;
                gap: 20px !important;
                page-break-inside: avoid !important;
            }

            /* Pembahagian Grid Metrik Kad Kewangan */
            .print-grid-metrics {
                display: grid !important;
                grid-template-columns: 1fr 1fr 1fr !important;
                gap: 15px !important;
            }
        }
