                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-pen-nib text-amber-400"></i>
                    <h3 id="modal-title" class="font-bold text-base">Tambah Maklumat Kursus</h3>
                </div>
                <button onclick="closeAddModal()" class="text-slate-400 hover:text-white transition">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
            <form id="course-form" onsubmit="handleFormSubmit(event)" class="p-6 space-y-4">
                <input type="hidden" id="form-course-id">
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Kategori Kumpulan</label>
                        <select id="form-kategori" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required>
                            <option value="Bukan Guru">Bukan Guru</option>
                            <option value="Guru">Guru</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Status Pelaksanaan</label>
                        <select id="form-status" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required>
                            <option value="Selesai">Selesai</option>
                            <option value="Tunda">Tunda</option>
                            <option value="Batal">Batal</option>
                            <option value="Belum Dilaksanakan">Belum Dilaksanakan</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Nama Kursus</label>
                    <input type="text" id="form-nama" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required placeholder="Contoh: Kursus Generative AI: Vibe Coding">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Objektif Kursus</label>
                        <textarea id="form-objektif" rows="2" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required placeholder="Contoh: Memperkasakan kepemimpinan berpengaruh melalui penguasaan teknik inovasi..."></textarea>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Outcome Kursus</label>
                        <textarea id="form-outcome" rows="2" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required placeholder="Contoh: Cadangan pelaksanaan kerangka Model Kepimpinan Adaptif di organisasi masing-masing..."></textarea>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Bilangan Peserta (Pax)</label>
                        <input type="number" id="form-pax" min="1" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Tarikh Kursus</label>
                        <input type="text" id="form-tarikh" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required placeholder="Contoh: 27 - 29 Julai 2026">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-slate-500 mb-1">Lokasi Kursus</label>
                    <input type="text" id="form-lokasi" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" required placeholder="Contoh: IAB Cawangan Genting Highlands">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">OS21 (RM)</label>
                        <input type="number" step="0.01" id="form-os21" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="0.00">
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 mb-1">OS29 (RM)</label>
                        <input type="number" step="0.01" id="form-os29" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="0.00">
                    </div>
                </div>

                <div class="flex justify-end gap-2 pt-4 border-t border-slate-150">
                    <button type="button" onclick="closeAddModal()" class="px-4 py-2 text-sm text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition">Batal</button>
                    <button type="submit" class="px-4 py-2 text-sm text-white bg-indigo-700 hover:bg-indigo-600 rounded-lg transition shadow-md">Simpan Rekod</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Custom Delete Confirmation Modal -->
    <div id="delete-modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center hidden no-print">
        <div class="bg-white rounded-xl shadow-2xl border border-slate-200 w-full max-w-md mx-4 overflow-hidden transform transition-all">
            <div class="p-6 text-center">
                <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-rose-50 text-rose-600 mb-4 border border-rose-100">
                    <i class="fa-solid fa-triangle-exclamation text-xl"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Hapus Rekod Kursus?</h3>
                <p class="text-sm text-slate-500 mb-6">Tindakan ini akan memadamkan data perbelanjaan kursus ini secara kekal daripada pengiraan waran.</p>
                <input type="hidden" id="delete-target-id">
                <div class="flex justify-center gap-3">
                    <button onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition">Batal</button>
                    <button onclick="confirmDelete()" class="px-4 py-2 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-500 rounded-lg transition shadow-md">Hapus Rekod</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification Toast -->
    <div id="notification-toast" class="fixed bottom-5 right-5 z-50 transform translate-y-10 opacity-0 transition-all duration-300 bg-slate-900 text-white px-4 py-3 rounded-xl shadow-xl flex items-center gap-2 max-w-xs pointer-events-none no-print">
        <span id="toast-icon-wrapper" class="text-amber-400"><i class="fa-solid fa-circle-info"></i></span>
        <p id="toast-message" class="text-xs font-semibold"></p>
    </div>

    <!-- JavaScript Data and Interactivity logic -->
    <script>
        // Constant official warrant ceiling amount
        const WARAN_CEILING = 313828.00;

        // Initializing data set with 'status' property added
        let courses = [
            {
                id: 1,
                kategori: 'Bukan Guru',
                nama: 'Kursus Generative AI : Vibe Coding',
                objektif: 'Memperkasakan kemahiran pembangunan kod (coding) berasaskan AI Generatif bagi Pegawai IT.',
                outcome: 'Pembangunan aplikasi prototaip pantas dan sistem automasi pengurusan di IAB.',
                pax: 15,
                tarikh: '27 - 29 Julai 2026',
                lokasi: 'IAB Cawangan Genting Highlands',
                os21: 25000.00,
                os29: 18500.00,
                status: 'Selesai'
            },
            {
                id: 2,
                kategori: 'Bukan Guru',
                nama: 'Kursus AWS dan Linux',
                objektif: 'Menguasai pentadbiran pelayan Linux dan pengurusan infrastruktur awan AWS.',
                outcome: 'Peningkatan ketersediaan (uptime) sistem dan pengoptimuman kos pengehosan pelayan awan KPM.',
                pax: 10,
                tarikh: '26 - 27 Ogos 2026',
                lokasi: 'Trainocate Kuala Lumpur',
                os21: 15000.00,
                os29: 8200.00,
                status: 'Tunda'
            },
            {
                id: 3,
                kategori: 'Guru',
                nama: '5-Day Executive Programme on Leadership, Innovation and AI Competency (Siri 1)',
                objektif: 'Memperkasakan kepemimpinan berpengaruh melalui penguasaan teknik inovasi & kompetensi AI bagi pensyarah/pegawai.',
                outcome: 'Cadangan pelaksanaan kerangka Model Kepimpinan Adaptif di institusi pendidikan masing-masing.',
                pax: 23,
                tarikh: '3 - 7 Ogos 2026',
                lokasi: 'USM, Pulau Pinang',
                os21: 85000.00,
                os29: 64000.00,
                status: 'Selesai'
            },
            {
                id: 4,
                kategori: 'Guru',
                nama: '5-Day Executive Programme on Leadership, Innovation and AI Competency (Siri 2)',
                objektif: 'Membangun keupayaan tadbir urus kepemimpinan dan integrasi alat AI dalam membuat keputusan strategik.',
                outcome: 'Pembudayaan automasi digital and pembinaan pelan bertindak transformasi kepimpinan sekolah.',
                pax: 23,
                tarikh: '7 - 11 September 2026',
                lokasi: 'USM, Pulau Pinang',
                os21: 85000.00,
                os29: 68000.00,
                status: 'Selesai'
            }
        ];

        let currentFilter = 'all';
        let currentSearch = '';

        // Formats numbers to RM Currency string
        function formatRM(val) {
            return new Intl.NumberFormat('ms-MY', { style: 'currency', currency: 'MYR' }).format(val);
        }

        // Live Date-Time Updater for 'last-updated-date'
        function touchUpdatedDate() {
            const now = new Date();
            const day = String(now.getDate()).padStart(2, '0');
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const year = now.getFullYear();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const seconds = String(now.getSeconds()).padStart(2, '0');
            
            const liveString = `${day}.${month}.${year} ${hours}:${minutes}:${seconds}`;
            document.getElementById('last-updated-date').innerText = liveString;
        }

        // Custom Notification Toast trigger
        function showToast(message, type = 'info') {
            const toast = document.getElementById('notification-toast');
            const iconWrapper = document.getElementById('toast-icon-wrapper');
            const msgEl = document.getElementById('toast-message');
            
            msgEl.innerText = message;
            if (type === 'error') {
                iconWrapper.innerHTML = '<i class="fa-solid fa-circle-exclamation text-rose-400"></i>';
            } else if (type === 'success') {
                iconWrapper.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-400"></i>';
            } else {
                iconWrapper.innerHTML = '<i class="fa-solid fa-circle-info text-sky-400"></i>';
            }

            toast.classList.remove('translate-y-10', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-10', 'opacity-0');
            }, 3500);
        }

        // Render Table Rows based on current states
        function renderTable() {
            const tbody = document.getElementById('course-table-body');
            tbody.innerHTML = '';

            // Dynamic header columns toggler (Objektif / Outcome only show on specific Guru/Bukan Guru tabs)
            const objOutHeaders = document.querySelectorAll('.col-obj-out');
            const grandTotalFooterText = document.getElementById('subtotal-title');

            if (currentFilter === 'all') {
                objOutHeaders.forEach(el => el.classList.add('hidden'));
                grandTotalFooterText.colSpan = 3; // Bil, Kategori, Nama Kursus
            } else {
                objOutHeaders.forEach(el => el.classList.remove('hidden'));
                grandTotalFooterText.colSpan = 5; // Bil, Kategori, Nama Kursus, Objektif, Outcome
            }

            let filtered = courses.filter(item => {
                const matchCat = currentFilter === 'all' || item.kategori === currentFilter;
                const matchSearch = item.nama.toLowerCase().includes(currentSearch.toLowerCase()) || 
                                    item.lokasi.toLowerCase().includes(currentSearch.toLowerCase()) ||
                                    item.objektif.toLowerCase().includes(currentSearch.toLowerCase()) ||
                                    item.outcome.toLowerCase().includes(currentSearch.toLowerCase());
                return matchCat && matchSearch;
            });

            if (filtered.length === 0) {
                const totalSpan = currentFilter === 'all' ? 10 : 12;
                tbody.innerHTML = `
                    <tr>
                        <td colspan="${totalSpan}" class="py-12 text-center text-slate-400 text-sm">
                            <i class="fa-solid fa-folder-open text-3xl mb-2 block"></i>
                            Tiada rekod kursus ditemui.
                        </td>
                    </tr>
                `;
                updateFooterValues(0, 0, 0, 0);
                return;
            }

            let subPax = 0, subOs21 = 0, subOs29 = 0, subTotal = 0;

            filtered.forEach((item, index) => {
                const totalItem = (Number(item.os21) || 0) + (Number(item.os29) || 0);
                subPax += Number(item.pax) || 0;
                subOs21 += Number(item.os21) || 0;
                subOs29 += Number(item.os29) || 0;
                subTotal += totalItem;

                const tr = document.createElement('tr');
                tr.className = 'hover:bg-slate-50/70 transition-colors text-sm text-slate-700';
                
                // Building standard cells
                let rowHTML = `
                    <td class="py-3 px-4 text-center font-semibold text-slate-400">${index + 1}</td>
                    <td class="py-3 px-3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                            item.kategori === 'Guru' ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-amber-50 text-amber-700 border border-amber-100'
                        }">
                            ${item.kategori}
                        </span>
                    </td>
                    <td class="py-3 px-4 font-semibold text-slate-900 leading-snug">${item.nama}</td>
                `;

                // Adding Objektif & Outcome only if currentFilter is not 'all'
                if (currentFilter !== 'all') {
                    rowHTML += `
                        <td class="py-3 px-4 text-xs text-slate-500 leading-relaxed max-w-[200px]">${item.objektif}</td>
                        <td class="py-3 px-4 text-xs text-slate-500 leading-relaxed max-w-[200px]">${item.outcome}</td>
                    `;
                }

                // Append remaining cells including the Execution Status inline select dropdown
                rowHTML += `
                    <td class="py-3 px-3 text-center font-medium">${item.pax}</td>
                    <td class="py-3 px-4 text-xs">
                        <div class="font-medium text-slate-600">${item.tarikh}</div>
                        <div class="text-slate-400 mt-0.5"><i class="fa-solid fa-location-dot text-indigo-500"></i> ${item.lokasi}</div>
                    </td>
                    <td class="py-3 px-4 text-right">
                        <div class="flex items-center justify-end gap-1">
                            <span class="text-slate-400 text-xs font-medium no-print">RM</span>
                            <input type="number" step="0.01" value="${item.os21}" onchange="updateCell(${item.id}, 'os21', this.value)" class="w-20 text-right bg-transparent border-b border-dashed border-slate-300 hover:border-slate-500 focus:border-indigo-500 focus:outline-none focus:bg-white px-1 py-0.5 rounded font-medium text-indigo-900">
                        </div>
                    </td>
                    <td class="py-3 px-4 text-right">
                        <div class="flex items-center justify-end gap-1">
                            <span class="text-slate-400 text-xs font-medium no-print">RM</span>
                            <input type="number" step="0.01" value="${item.os29}" onchange="updateCell(${item.id}, 'os29', this.value)" class="w-20 text-right bg-transparent border-b border-dashed border-slate-300 hover:border-slate-500 focus:border-indigo-500 focus:outline-none focus:bg-white px-1 py-0.5 rounded font-medium text-sky-900">
                        </div>
                    </td>
                    <td class="py-3 px-4 text-right font-bold text-slate-800">${formatRM(totalItem)}</td>
                    
                    <!-- Dynamic Status Pelaksanaan Interactive Dropdown -->
                    <td class="py-3 px-4 text-center">
                        <select onchange="updateCell(${item.id}, 'status', this.value)" class="text-xs font-semibold rounded-full px-2.5 py-1.5 border focus:outline-none transition-all shadow-sm ${
                            item.status === 'Selesai' ? 'bg-emerald-50 text-emerald-700 border-emerald-200 focus:ring-emerald-500' :
                            item.status === 'Tunda' ? 'bg-amber-50 text-amber-700 border-amber-200 focus:ring-amber-500' :
                            item.status === 'Batal' ? 'bg-rose-50 text-rose-700 border-rose-200 focus:ring-rose-500' :
                            'bg-slate-100 text-slate-700 border-slate-300 focus:ring-slate-500'
                        }">
                            <option value="Selesai" ${item.status === 'Selesai' ? 'selected' : ''}>✅ Selesai</option>
                            <option value="Tunda" ${item.status === 'Tunda' ? 'selected' : ''}>⏳ Tunda</option>
                            <option value="Batal" ${item.status === 'Batal' ? 'selected' : ''}>❌ Batal</option>
                            <option value="Belum Dilaksanakan" ${item.status === 'Belum Dilaksanakan' ? 'selected' : ''}>⚪ Belum Dilaksanakan</option>
                        </select>
                    </td>

                    <td class="py-3 px-3 text-center no-print col-actions">
                        <div class="flex items-center justify-center gap-1">
                            <button onclick="editCourse(${item.id})" class="p-1.5 text-blue-600 hover:bg-blue-50 hover:text-blue-700 rounded-md transition" title="Edit Kursus">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <button onclick="triggerDeleteCourse(${item.id})" class="p-1.5 text-rose-600 hover:bg-rose-50 hover:text-rose-700 rounded-md transition" title="Hapus Kursus">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </td>
                `;

                tr.innerHTML = rowHTML;
                tbody.appendChild(tr);
            });

            updateFooterValues(subPax, subOs21, subOs29, subTotal);
        }

        // Update values in bottom totals bar
        function updateFooterValues(pax, os21, os29, total) {
            document.getElementById('grand-pax').innerText = pax;
            document.getElementById('grand-os21').innerText = formatRM(os21);
            document.getElementById('grand-os29').innerText = formatRM(os29);
            document.getElementById('grand-total').innerText = formatRM(total);
        }

        // Directly update cell data from the table input edits
        function updateCell(id, key, value) {
            const target = courses.find(item => item.id === id);
            if (target) {
                if (key === 'status') {
                    target[key] = value;
                } else {
                    target[key] = Math.max(0, parseFloat(value) || 0);
                }
                touchUpdatedDate();
                renderTable();
                calculateOverall();
                showToast("Data peruntukan waran berjaya dikemaskini!", "success");
            }
        }

        // Calculate overarching data figures
        function calculateOverall() {
            let totalOs21 = 0;
            let totalOs29 = 0;
            let totalBukanGuru = 0;
            let totalGuru = 0;

            courses.forEach(item => {
                const itemVal21 = Number(item.os21) || 0;
                const itemVal29 = Number(item.os29) || 0;
                const totalItem = itemVal21 + itemVal29;

                totalOs21 += itemVal21;
                totalOs29 += itemVal29;

                if (item.kategori === 'Guru') {
                    totalGuru += totalItem;
                } else {
                    totalBukanGuru += totalItem;
                }
            });

            const overallTotal = totalOs21 + totalOs29;
            document.getElementById('total-belanja').innerText = overallTotal.toLocaleString('ms-MY', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            // Budget calculations based on fixed warrant ceiling budget
            const siling = WARAN_CEILING;
            const baki = siling - overallTotal;
            const bakiText = document.getElementById('baki-belanja');
            const bakiContainer = document.getElementById('baki-belanja-container');
            const bakiIconContainer = document.getElementById('baki-icon-container');

            bakiText.innerText = baki.toLocaleString('ms-MY', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            if (baki >= 0) {
                bakiContainer.className = 'text-2xl font-bold mt-1 text-emerald-600';
                bakiIconContainer.className = 'p-3 bg-emerald-50 text-emerald-600 rounded-lg border border-emerald-100';
            } else {
                bakiContainer.className = 'text-2xl font-bold mt-1 text-rose-600';
                bakiIconContainer.className = 'p-3 bg-rose-50 text-rose-600 rounded-lg animate-pulse border border-rose-200';
                // Trigger a toast warning if budget is exceeded
                setTimeout(() => {
                    showToast("Amaran: Perbelanjaan melebihi peruntukan waran!", "error");
                }, 500);
            }

            // Rates progress bar
            const rate = Math.round((overallTotal / siling) * 100);
            document.getElementById('utilization-rate').innerText = `${rate}%`;
            const utilizationBar = document.getElementById('utilization-bar');
            utilizationBar.style.width = `${Math.min(100, rate)}%`;

            if (rate > 100) {
                utilizationBar.className = 'bg-rose-600 h-3 rounded-full transition-all duration-500';
            } else if (rate > 85) {
                utilizationBar.className = 'bg-amber-500 h-3 rounded-full transition-all duration-500';
            } else {
                utilizationBar.className = 'bg-indigo-600 h-3 rounded-full transition-all duration-500';
            }

            // Object-Sebagai Progress Charts
            const totalOSCombined = totalOs21 + totalOs29 || 1;
            const pctOs21 = Math.round((totalOs21 / totalOSCombined) * 100);
            const pctOs29 = Math.round((totalOs29 / totalOSCombined) * 100);

            document.getElementById('percent-os21').innerText = `${pctOs21}%`;
            document.getElementById('percent-os29').innerText = `${pctOs29}%`;
            document.getElementById('bar-os21').style.width = `${pctOs21}%`;
            document.getElementById('bar-os29').style.width = `${pctOs29}%`;
            document.getElementById('val-os21').innerText = formatRM(totalOs21);
            document.getElementById('val-os29').innerText = formatRM(totalOs29);

            // Group Comparison Charts
            const totalGroupsCombined = totalBukanGuru + totalGuru || 1;
            const pctBukanGuru = Math.round((totalBukanGuru / totalGroupsCombined) * 100);
            const pctGuru = Math.round((totalGuru / totalGroupsCombined) * 100);

            document.getElementById('percent-bukan-guru').innerText = `${pctBukanGuru}%`;
            document.getElementById('percent-guru').innerText = `${pctGuru}%`;
            document.getElementById('bar-bukan-guru').style.width = `${pctBukanGuru}%`;
            document.getElementById('bar-guru').style.width = `${pctGuru}%`;
            document.getElementById('val-bukan-guru').innerText = formatRM(totalBukanGuru);
            document.getElementById('val-guru').innerText = formatRM(totalGuru);
        }

        // Filter functionality
        function filterCategory(cat) {
            currentFilter = cat;
            
            // Toggle active classes
            const btns = {
                all: document.getElementById('btn-all'),
                'Bukan Guru': document.getElementById('btn-bukan-guru'),
                Guru: document.getElementById('btn-guru')
            };

            Object.keys(btns).forEach(key => {
                if (key === cat) {
                    btns[key].className = 'px-4 py-1.5 rounded-md text-sm font-medium transition bg-slate-900 text-white';
                } else {
                    btns[key].className = 'px-4 py-1.5 rounded-md text-sm font-medium transition text-slate-600 hover:text-slate-900';
                }
            });

            renderTable();
        }

        // Search text input triggers
        function handleSearch() {
            currentSearch = document.getElementById('search-input').value;
            renderTable();
        }

        // Modal Controls
        function openAddModal() {
            document.getElementById('modal-title').innerText = 'Tambah Maklumat Kursus';
            document.getElementById('course-form').reset();
            document.getElementById('form-course-id').value = '';
            document.getElementById('course-modal').classList.remove('hidden');
        }

        function closeAddModal() {
            document.getElementById('course-modal').classList.add('hidden');
        }

        // Process Add/Edit form inputs
        function handleFormSubmit(e) {
            e.preventDefault();

            const editId = document.getElementById('form-course-id').value;
            const data = {
                kategori: document.getElementById('form-kategori').value,
                nama: document.getElementById('form-nama').value,
                objektif: document.getElementById('form-objektif').value,
                outcome: document.getElementById('form-outcome').value,
                pax: parseInt(document.getElementById('form-pax').value) || 0,
                tarikh: document.getElementById('form-tarikh').value,
                lokasi: document.getElementById('form-lokasi').value,
                os21: parseFloat(document.getElementById('form-os21').value) || 0,
                os29: parseFloat(document.getElementById('form-os29').value) || 0,
                status: document.getElementById('form-status').value,
            };

            if (editId) {
                // Edit existing record
                const idx = courses.findIndex(item => item.id === parseInt(editId));
                if (idx !== -1) {
                    courses[idx] = { ...courses[idx], ...data };
                }
                showToast("Rekod kursus berjaya dikemaskini!", "success");
            } else {
                // Add new record
                const newId = courses.length > 0 ? Math.max(...courses.map(c => c.id)) + 1 : 1;
                courses.push({ id: newId, ...data });
                showToast("Rekod kursus baru berjaya ditambah!", "success");
            }

            touchUpdatedDate();
            closeAddModal();
            renderTable();
            calculateOverall();
        }

        // Trigger editing fill
        function editCourse(id) {
            const item = courses.find(c => c.id === id);
            if (!item) return;

            document.getElementById('modal-title').innerText = 'Sunting Maklumat Kursus';
            document.getElementById('form-course-id').value = item.id;
            document.getElementById('form-kategori').value = item.kategori;
            document.getElementById('form-nama').value = item.nama;
            document.getElementById('form-objektif').value = item.objektif;
            document.getElementById('form-outcome').value = item.outcome;
            document.getElementById('form-pax').value = item.pax;
            document.getElementById('form-tarikh').value = item.tarikh;
            document.getElementById('form-lokasi').value = item.lokasi;
            document.getElementById('form-os21').value = item.os21;
            document.getElementById('form-os29').value = item.os29;
            document.getElementById('form-status').value = item.status;

            document.getElementById('course-modal').classList.remove('hidden');
        }

        // Delete modal handling
        function triggerDeleteCourse(id) {
            document.getElementById('delete-target-id').value = id;
            document.getElementById('delete-modal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('delete-modal').classList.add('hidden');
        }

        function confirmDelete() {
            const id = parseInt(document.getElementById('delete-target-id').value);
            courses = courses.filter(item => item.id !== id);
            closeDeleteModal();
            touchUpdatedDate();
            renderTable();
            calculateOverall();
            showToast("Rekod kursus berjaya dipadamkan.", "info");
        }

        // Export data structure to CSV
        function exportData() {
            let csvContent = "data:text/csv;charset=utf-8,";
            csvContent += "Bil,Kategori,Nama Kursus,Objektif,Outcome,Pax,Tarikh,Lokasi,OS21 (Sewa),OS29 (Latihan/Tuntutan),Jumlah (RM),Status\n";

            courses.forEach((item, index) => {
                const totalItem = item.os21 + item.os29;
                const row = [
                    index + 1,
                    `"${item.kategori}"`,
                    `"${item.nama}"`,
                    `"${item.objektif.replace(/"/g, '""')}"`,
                    `"${item.outcome.replace(/"/g, '""')}"`,
                    item.pax,
                    `"${item.tarikh}"`,
                    `"${item.lokasi}"`,
                    item.os21.toFixed(2),
                    item.os29.toFixed(2),
                    totalItem.toFixed(2),
                    `"${item.status}"`
                ].join(",");
                csvContent += row + "\n";
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "Laporan_Perbelanjaan_Waran_JPA_2026.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast("Laporan CSV berjaya dimuat turun!", "success");
        }

        // On Load Initializers
        window.onload = function() {
            renderTable();
            calculateOverall();
            touchUpdatedDate(); // Live load time
        };
    </script>
</body>
</html>
